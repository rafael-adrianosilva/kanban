{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/tarefas(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/categorias(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/estatisticas(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/usuario(.*)",
      "destination": "api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}